__openclaw_lazy_completion_loaded=0
_openclaw_lazy_load_completion() {
  (( __openclaw_lazy_completion_loaded )) && return 0
  __openclaw_lazy_completion_loaded=1

  local cache_dir="${XDG_CACHE_HOME:-$HOME/Library/Caches}/zsh/openclaw"
  mkdir -p "$cache_dir"
  local cache_file="$cache_dir/completion.zsh"

  if [[ ! -s "$cache_file" ]]; then
  fi
  source "$cache_file" 2>/dev/null || true
}
# 在补全系统启动后，第一次触发补全前加载
autoload -Uz add-zsh-hook
add-zsh-hook precmd _openclaw_lazy_load_completion


